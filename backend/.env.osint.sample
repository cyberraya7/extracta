## Copy these lines into backend/.env and restart backend.
## Paths below are tailored for this machine/workspace.

EXTRACTA_OSINT_TIMEOUT_SECONDS=30
EXTRACTA_OSINT_MAX_ENTITIES=100

## Optional: override upload root directory.
## Uploaded files are saved under YYYY/MM/DD subfolders beneath this root.
# EXTRACTA_UPLOAD_DIR=/absolute/path/to/uploads-root

## Instagram leak NDJSON (Investigation → Leak database). Relative paths resolve under backend/.
# EXTRACTA_INSTAGRAM_LEAK_PATH=/absolute/path/to/Instagram-leak.json

## Email: registered websites via Holehe wrapper
EXTRACTA_OSINT_EMAIL_SITES_CMD="python3 /Users/luqie/Documents/cursor/yose/backend/email_lookup.py \"{value}\""

## Legacy fallback if EMAIL_SITES_CMD is unset (batch OSINT / older configs)
# EXTRACTA_OSINT_EMAIL_CMD="python3 .../email_lookup.py \"{value}\""

## Phone: wrapper uses telegram-phone-number-checker CLI internally.
EXTRACTA_OSINT_PHONE_CMD="python3 /Users/luqie/Documents/cursor/yose/backend/phone_lookup.py \"{value}\""

## Username: wrapper uses Maigret internally.
## Install from https://github.com/soxoj/maigret
## Keep {value} in command template; wrapper reads EXTRACTA_MAIGRET_CMD.
EXTRACTA_MAIGRET_CMD="maigret \"{value}\" --json simple"
EXTRACTA_OSINT_USERNAME_CMD="python3 /Users/luqie/Documents/cursor/yose/backend/username_lookup.py \"{value}\""
EXTRACTA_OSINT_ORG_CMD="python3 /Users/luqie/Documents/cursor/yose/backend/org_lookup.py \"{value}\""
